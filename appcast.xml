        <!--
        RELEASE PROCESS:
        1. Build for release: Product → Archive in Xcode
        2. Export notarized app, create DMG
        3. Sign the DMG: ./sign_update CropBatch-vX.X.dmg
        4. Copy the signature from output
        5. Add new <item> below with version, signature, download URL
        6. Push appcast.xml to main branch
        -->

        <!-- Latest release first -->
        <item>
            <title>Version 1.4</title>
            <description><![CDATA[
                <h2>What's New in 1.4</h2>
                <ul>
                    <li>Grid Split — divide cropped images into rows and columns with customizable tile naming</li>
                    <li>Corner Radius auto-switches to PNG format for transparency</li>
                    <li>Blur regions now export at correct coordinates</li>
                    <li>Watermark color picker fixed</li>
                    <li>Image switching no longer flashes</li>
                    <li>Swift 6 concurrency safety improvements</li>
                </ul>
            ]]></description>
            <pubDate>Thu, 03 Apr 2026 18:00:00 +0000</pubDate>
            <enclosure
                url="https://github.com/Xpycode/CropBatch/releases/download/v1.4/CropBatch-1.4.dmg"
